geom_point(alpha = 0.8, size = 1.5) +
scale_color_manual(values = c("Significant" = "red", "Not Significant" = "gray")) +
labs(
title = "Volcano Plot: Laser Condition",
x = "Log2 Fold Change",
y = "-Log10 Adjusted P-Value",
color = "Significance"
) +
theme_minimal() +
theme(
