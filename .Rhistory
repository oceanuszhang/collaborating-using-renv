# Convert relevant columns to factors
data <- data %>%
mutate(
antibiotic_prescribed = factor(antibiotic_prescribed, levels = c(0, 1), labels = c("Not Prescribed", "Prescribed")),
appointment_type = factor(appointment_type, levels = c("In-Person", "Telemedicine")),
race = factor(race),
gender = factor(gender),
insurance_type = factor(insurance_type),
htn = factor(htn, levels = c(0, 1), labels = c("None", "Diagnosed"))
)
# 1. Sensitivity Analyses
# Exclude highlighted clinics
sensitivity_clinics <- data %>%
filter(!clinic %in% c("Clinic1", "Clinic2", "Clinic3"))  # Replace with actual clinic names or IDs
# Load necessary libraries
library(dplyr)
library(readxl)
# Load dataset
file_path <- "/Users/oceanuszhang/Desktop/EHC Telemedicine vs. In-Person Appointments with Antimicrobial Usage_v2.xlsx"
data <- read_excel(file_path)
# Clean variable names
data <- janitor::clean_names(data)
# Print all variable names in the dataset
print(names(data))
### SENSITIVITY
# Sensitivity Analyses
# Exclude dark red ICD-10 codes (replace "CodeA" and "CodeB" with actual ICD-10 codes)
sensitivity_icd10_dark_red <- data %>%
filter(!icd_10_diagnosis_code %in% c("CodeA", "CodeB"))  # Replace with dark red codes
# Exclude dark and light red ICD-10 codes
sensitivity_icd10_red_codes <- data %>%
filter(!icd_10_diagnosis_code %in% c("CodeA", "CodeB", "CodeC", "CodeD"))  # Replace with all highlighted codes
# Logistic Regression Models for Sensitivity Analyses
sensitivity_models <- list(
icd10_dark_red_excluded = glm(antibiotic_prescribed ~ appointment_type + race * appointment_type + age + gender +
charlson_comorbidity_index + htn + insurance_type,
family = binomial(link = 'logit'), data = sensitivity_icd10_dark_red),
icd10_red_codes_excluded = glm(antibiotic_prescribed ~ appointment_type + race * appointment_type + age + gender +
charlson_comorbidity_index + htn + insurance_type,
family = binomial(link = 'logit'), data = sensitivity_icd10_red_codes)
)
# Display results for sensitivity analyses
library(sjPlot)
for (name in names(sensitivity_models)) {
cat("\nSensitivity Analysis:", name, "\n")
print(tab_model(sensitivity_models[[name]], show.est = TRUE, show.ci = TRUE))
}
# Display results for sensitivity analyses with faster Wald confidence intervals
library(sjPlot)
for (name in names(sensitivity_models)) {
cat("\nSensitivity Analysis:", name, "\n")
print(tab_model(sensitivity_models[[name]], show.est = TRUE, show.ci = TRUE, ci_method = "wald"))
}
# Load necessary libraries
library(dplyr)
library(readxl)
library(sjPlot)
# Load and clean dataset
file_path <- "/Users/oceanuszhang/Desktop/EHC Telemedicine vs. In-Person Appointments with Antimicrobial Usage_v2.xlsx"
data <- read_excel(file_path)
data <- janitor::clean_names(data)
# Print all variable names in the dataset
print(names(data))
# Convert relevant columns to factors and specify levels as needed
data <- data %>%
mutate(
antibiotic_prescribed = factor(antibiotic_prescribed, levels = c(0, 1), labels = c("Not Prescribed", "Prescribed")),
appointment_type = factor(appointment_type, levels = c("In-Person", "Telemedicine")),
race = factor(race),
gender = factor(gender),
insurance_type = factor(insurance_type),
htn = factor(htn, levels = c(0, 1), labels = c("None", "Diagnosed"))
)
### SENSITIVITY
# Sensitivity Analyses: Exclude ICD-10 codes
# Replace "CodeA", "CodeB", etc. with actual ICD-10 codes as needed
# Exclude dark red ICD-10 codes
sensitivity_icd10_dark_red <- data %>%
filter(!icd_10_diagnosis_code %in% c("CodeA", "CodeB"))  # Replace with dark red codes
# Exclude dark and light red ICD-10 codes
sensitivity_icd10_red_codes <- data %>%
filter(!icd_10_diagnosis_code %in% c("CodeA", "CodeB", "CodeC", "CodeD"))  # Replace with all highlighted codes
# Create logistic regression models for each sensitivity analysis
sensitivity_models <- list(
icd10_dark_red_excluded = glm(antibiotic_prescribed ~ appointment_type + race * appointment_type + age + gender +
charlson_comorbidity_index + htn + insurance_type,
family = binomial(link = 'logit'), data = sensitivity_icd10_dark_red),
icd10_red_codes_excluded = glm(antibiotic_prescribed ~ appointment_type + race * appointment_type + age + gender +
charlson_comorbidity_index + htn + insurance_type,
family = binomial(link = 'logit'), data = sensitivity_icd10_red_codes)
)
# Display results for sensitivity analyses with Wald confidence intervals
for (name in names(sensitivity_models)) {
cat("\nSensitivity Analysis:", name, "\n")
print(tab_model(sensitivity_models[[name]], show.est = TRUE, show.ci = TRUE, ci_method = "wald"))
}
View(data)
