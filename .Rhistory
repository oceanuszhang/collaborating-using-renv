# Packgage Preperation
library(edgeR)
library(limma)
library(openxlsx)
library(ggplot2)
library(dplyr)
library(tidyverse)
library(ComplexHeatmap)
library(factoextra)
library(ggpmisc)
rm(list=ls())
# Import and read in Data
GBM_data <- "/Users/oceanuszhang/Library/CloudStorage/OneDrive-EmoryUniversity/MPH/MPH 2nd Year/Fall 24/GBM/GBM_Oceanus/GBM_DATA_OC/GBM_normalized.csv"
GBM_norm <- read.csv(GBM_data, row.names = 1)
# Filter the data to keep only columns related to xenoline JX39P
GBM_JX39P <- GBM_norm[, grepl("JX39P", colnames(GBM_norm))]
# Check the dimensions to ensure only JX39P data is present
cat("Dimensions of GBM_JX39P (filtered dataframe):", dim(GBM_JX39P), "\n")
# Display the first few rows to confirm the filtering step
head(GBM_JX39P)
# Extract condition information based on the presence of '5Gy' in the column names
conditions <- ifelse(grepl("5Gy", colnames(GBM_JX39P)), "Laser", "Control")
# Create the design matrix for the differential expression analysis
design_matrix <- model.matrix(~ 0 + conditions)
colnames(design_matrix) <- levels(factor(conditions))
# Perform voom transformation on gene expression data
v <- voom(GBM_JX39P, design_matrix, plot = TRUE)
# Fit the linear model using limma
fit <- lmFit(v, design_matrix)
# Define the contrast to compare Laser vs. Control conditions
contrast_matrix <- makeContrasts(Laser_vs_Control = Laser - Control, levels = design_matrix)
# Apply the contrast to the linear model
fit2 <- contrasts.fit(fit, contrast_matrix)
fit2 <- eBayes(fit2)
# Get the top differentially expressed genes
top_results <- topTable(fit2, adjust = "BH", number = Inf)
# Display the first few rows of the top differentially expressed genes
head(top_results)
# Save the results to an Excel file
file_path <- "/Users/oceanuszhang/Desktop/pathway/JX39P_Laser_vs_Control_results.xlsx"
top_results$Gene_Name <- rownames(top_results)
write.xlsx(top_results, file = file_path)
cat("Saved results to", file_path, "\n")
# Load ggplot2 for plotting
library(ggplot2)
# Prepare data for volcano plot
volcano_data <- top_results
volcano_data$Significance <- "Not Significant"
volcano_data$Significance[volcano_data$adj.P.Val < 0.05 & abs(volcano_data$logFC) > 1] <- "Significant"
# Create volcano plot
ggplot(volcano_data, aes(x = logFC, y = -log10(adj.P.Val), color = Significance)) +
geom_point(alpha = 0.8, size = 1.5) +
scale_color_manual(values = c("Significant" = "red", "Not Significant" = "gray")) +
labs(
title = "Volcano Plot: Laser vs. Control in JX39P",
x = "Log2 Fold Change (Laser vs. Control)",
y = "-Log10 Adjusted P-Value",
color = "Significance"
) +
theme_minimal() +
theme(
plot.title = element_text(hjust = 0.5, face = "bold"),
legend.position = "top"
) +
geom_vline(xintercept = c(-1, 1), linetype = "dashed", color = "black") +
geom_hline(yintercept = -log10(0.05), linetype = "dashed", color = "black")
# Save the volcano plot to a file
ggsave("/Users/oceanuszhang/Desktop/pathway/JX39P_Volcano_Plot.png", width = 10, height = 8)
cat("Volcano plot saved to /Users/oceanuszhang/Desktop/pathway/JX39P_Volcano_Plot.png\n")
# Calculate average expression for each gene in each condition
GBM_JX39P$Laser <- rowMeans(GBM_JX39P[, grepl("Laser", colnames(GBM_JX39P))])
GBM_JX39P$Control <- rowMeans(GBM_JX39P[, grepl("Control", colnames(GBM_JX39P))])
# Convert to long format for plotting
library(reshape2)
expression_data_long <- melt(GBM_JX39P, id.vars = "Gene_Name", measure.vars = c("Laser", "Control"), variable.name = "Condition", value.name = "Expression")
# Create mock "Laser" volcano plot (comparing Laser to a baseline)
