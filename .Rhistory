# Display the summary table
summary_table
# Load the dataset
mydata <- read_sas("/Users/oceanuszhang/Desktop/mydata.sas7bdat")
# Initialize an empty list to store model results
model_list <- list()
# Loop over variables AAA to JJJ to fit univariable Cox models
for (var in names(mydata)[5:14]) {  # Assuming AAA to JJJ are columns 5 to 14
# Create the formula dynamically with TIME as the survival time and CENSOR as censoring
formula <- as.formula(paste("Surv(TIME, CENSOR) ~", var, "+ EXPOSURE"))
# Fit Cox proportional hazards model with error handling
model <- tryCatch({
coxph(formula, data = mydata)
}, error = function(e) {
message("Skipping variable ", var, " due to error: ", e$message)
return(NULL)
})
# Only proceed if the model was successfully fitted
if (!is.null(model)) {
# Tidy the model output, calculate HR and CI, and adjust term labels
model_tidy <- broom::tidy(model) %>%
mutate(
variable = var,
HR = exp(estimate),  # Calculate Hazard Ratio
CI_lower = exp(estimate - 1.96 * std.error), # 95% CI lower bound
CI_upper = exp(estimate + 1.96 * std.error),  # 95% CI upper bound
term = ifelse(term == "EXPOSURE", "Exposure=1", "Exposure=0")  # Update term labels
)
# Append the results to the model_list
model_list[[var]] <- model_tidy
}
}
# Combine all model results into a single data frame
results <- bind_rows(model_list)
# Filter and rename columns for clarity
results_summary <- results %>%
select(variable, term, estimate, std.error, HR, CI_lower, CI_upper, statistic, p.value) %>%
rename(
"Variable" = variable,
"Exposure Group" = term,
"Parameter Estimate" = estimate,
"Standard Error" = std.error,
"Hazard Ratio (HR)" = HR,
"95% CI Lower" = CI_lower,
"95% CI Upper" = CI_upper,
"Z Score" = statistic,
"P Value" = p.value
)
# Convert to tibble
results_summary <- as_tibble(results_summary)
# Format the summary table using gt for a nicely formatted table
summary_table <- results_summary %>%
gt() %>%
tab_header(
title = md("**Univariable Analysis of Survival Time**")
) %>%
fmt_number(
columns = c("Parameter Estimate", "Standard Error", "Hazard Ratio (HR)", "95% CI Lower", "95% CI Upper", "Z Score", "P Value"),
decimals = 2
) %>%
cols_label(
Variable = "Variable",
`Exposure Group` = "Exposure Group",
`Parameter Estimate` = "Parameter Estimate",
`Standard Error` = "Standard Error",
`Hazard Ratio (HR)` = "Hazard Ratio (HR)",
`95% CI Lower` = "95% CI (Lower)",
`95% CI Upper` = "95% CI (Upper)",
`Z Score` = "Z Score",
`P Value` = "P Value"
) %>%
tab_style(
style = cell_text(weight = "bold"),
locations = cells_column_labels()
)
# Display the summary table
summary_table
# Part C
model_ccc_fff <- coxph(Surv(TIME, CENSOR) ~ CCC + FFF, data = mydata)
# Display the summary of the model
summary(model_ccc_fff)
# Tidy the model output for a clearer view
model_ccc_fff_tidy <- broom::tidy(model_ccc_fff)
model_ccc_fff_tidy
