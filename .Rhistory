mydata$EXPOSURE <- as.factor(mydata$EXPOSURE)
mydata$BBB <- as.factor(mydata$BBB)
mydata$DDD <- as.factor(mydata$DDD)
mydata$EEE <- as.factor(mydata$EEE)
mydata$GGG <- as.factor(mydata$GGG)
mydata$HHH <- as.factor(mydata$HHH)
# Fit the Cox proportional hazards model
cox_model <- coxph(Surv(TIME, CENSOR) ~ EXPOSURE + AAA + BBB + CCC + DDD + EEE + FFF + GGG + HHH + III + JJJ, data = mydata)
# Summarize the model to see the output
summary(cox_model)
# Tidy the model output with adjusted hazard ratios and confidence intervals
tidy_cox <- tidy(cox_model, exponentiate = TRUE, conf.int = TRUE)
tidy_cox
